# Сгенерируйте отдельный длинный ключ: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret

# Логин администратора и хэш пароля. Сам пароль здесь не хранится.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-with-generated-password-hash

# Пути могут быть абсолютными или относительными корню проекта.
DATABASE_PATH=backend/instance/portfolio.db
UPLOAD_FOLDER=backend/uploads
STAGING_FOLDER=backend/instance/staging

# Ограничения и параметры безопасности.
MAX_UPLOAD_MB=20
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
SESSION_LIFETIME_HOURS=8
SESSION_COOKIE_SECURE=false
TRUST_PROXY=false
